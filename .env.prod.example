# ─────────────────────────────────────────────────────────────────────────
# Saptta PRODUCTION env — copy to `.env.prod`, fill REAL values, keep secret.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"                                   # *_SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"      # HR_FIELD_ENCRYPTION_KEY
# ─────────────────────────────────────────────────────────────────────────

# Database
POSTGRES_DB=saptta_prod
POSTGRES_USER=saptta
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password

# Django secrets (32+ bytes each)
FIN_SECRET_KEY=CHANGE-ME-48-char-random
HR_SECRET_KEY=CHANGE-ME-another-48-char-random
HR_FIELD_ENCRYPTION_KEY=CHANGE-ME-fernet-key

# Hosts / domains (replace example.com with your domain)
DJANGO_ALLOWED_HOSTS=app.saptta.example.com,.saptta.example.com
HR_ALLOWED_HOSTS=hr.saptta.example.com,.saptta.example.com
HR_SUPERADMIN_DOMAIN=app.saptta.example.com
HR_TENANT_DOMAIN=saptta.example.com
CORS_ALLOWED_ORIGINS=https://app.saptta.example.com
CSRF_TRUSTED_ORIGINS=https://app.saptta.example.com,https://*.saptta.example.com

# Frontend (Vite build-time — baked into the SPA bundle)
VITE_PLATFORM_API_BASE_URL=https://app.saptta.example.com/api/v1
VITE_TENANT_API_BASE_URL=https://{workspace}.saptta.example.com/api/v1
VITE_HR_BASE_URL=https://hr.saptta.example.com
FRONTEND_BASE_URL=https://app.saptta.example.com

# Account security
REQUIRE_EMAIL_VERIFICATION=True

# Shared secret for HR single sign-on + internal provisioning (fin <-> hr).
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SSO_SHARED_SECRET=CHANGE-ME-shared-sso-secret

# Transactional email (example: AWS SES SMTP, or any SMTP provider)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.ap-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE-ME-smtp-user
EMAIL_HOST_PASSWORD=CHANGE-ME-smtp-password
DEFAULT_FROM_EMAIL=Saptta <no-reply@saptta.example.com>

# TLS certificate directory (must contain fullchain.pem + privkey.pem)
TLS_CERT_DIR=./deploy/certs

# Database backups: host path for nightly pg_dump output + retention (days).
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14

# Sentry error tracking (optional; leave blank to disable). Separate DSNs per
# backend so issues are attributed to the right project.
FIN_SENTRY_DSN=
HR_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
