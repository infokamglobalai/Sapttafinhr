# ─────────────────────────────────────────────────────────────────────────
# Saptta PRODUCTION env — copy to `.env.prod`, fill REAL values, keep secret.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# Generate secrets (run on the server):
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"          # *_SECRET_KEY
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # HR_FIELD_ENCRYPTION_KEY
# ─────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=saptta_prod
POSTGRES_USER=saptta
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password

# ── Django secrets (generate fresh — never reuse dev keys) ────────────────
FIN_SECRET_KEY=CHANGE-ME-48-char-random
HR_SECRET_KEY=CHANGE-ME-another-48-char-random
HR_FIELD_ENCRYPTION_KEY=CHANGE-ME-fernet-key

# ── Domains ───────────────────────────────────────────────────────────────
DJANGO_ALLOWED_HOSTS=app.saptta.com,.saptta.com,saptta.com
HR_ALLOWED_HOSTS=hr.saptta.com,.saptta.com
HR_SUPERADMIN_DOMAIN=hr.saptta.com
HR_TENANT_DOMAIN=saptta.com
CORS_ALLOWED_ORIGINS=https://app.saptta.com,https://saptta.com
CSRF_TRUSTED_ORIGINS=https://app.saptta.com,https://saptta.com,https://*.saptta.com

# ── Frontend build-time vars (baked into the SPA bundles at build) ────────
VITE_PLATFORM_API_BASE_URL=https://app.saptta.com/api/v1
VITE_TENANT_API_BASE_URL=https://{workspace}.saptta.com/api/v1
VITE_HR_BASE_URL=https://hr.saptta.com
VITE_FINANCE_APP_BASE_URL=https://{workspace}.saptta.com
FRONTEND_BASE_URL=https://app.saptta.com
VITE_FIN_PLATFORM_BASE_URL=https://app.saptta.com

# ── Security ──────────────────────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION=False
SSO_SHARED_SECRET=CHANGE-ME-shared-sso-secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Use any SMTP: Gmail, SendGrid, AWS SES, Mailgun, Brevo, etc.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE-ME-your@email.com
EMAIL_HOST_PASSWORD=CHANGE-ME-app-password
DEFAULT_FROM_EMAIL=Saptta <no-reply@saptta.com>

# ── India tax compliance (GSP proxy) ─────────────────────────────────────
# STUB = deterministic fake IRN/EWB for dev/demo. LIVE = call GSP REST API.
EINVOICE_MODE=STUB
EWB_MODE=STUB
NIC_IRP_BASE_URL=
NIC_IRP_CLIENT_ID=
NIC_IRP_CLIENT_SECRET=
NIC_IRP_GSTIN=
EWB_BASE_URL=
EWB_USERNAME=
EWB_PASSWORD=

# ── GCC tax compliance ────────────────────────────────────────────────────
ZATCA_MODE=STUB
ZATCA_BASE_URL=
ZATCA_CLIENT_ID=
ZATCA_CLIENT_SECRET=
PEPPOL_MODE=STUB
PEPPOL_BASE_URL=
PEPPOL_API_KEY=

# ── SaaS vendor GST (subscription invoices) ───────────────────────────────
SAAS_VENDOR_GSTIN=27AABCZ1234A1Z5
SAAS_VENDOR_STATE_CODE=27

# ── Razorpay (live checkout) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── HR email (same SMTP as finance by default) ────────────────────────────
HR_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
HR_EMAIL_HOST=smtp.gmail.com
HR_EMAIL_PORT=587
HR_EMAIL_HOST_USER=CHANGE-ME-your@email.com
HR_EMAIL_HOST_PASSWORD=CHANGE-ME-app-password
HR_EMAIL_USE_TLS=True

# ── TLS certificates (Let's Encrypt via certbot) ──────────────────────────
TLS_CERT_DIR=/etc/letsencrypt/live/saptta.com

# ── Backups ───────────────────────────────────────────────────────────────
BACKUP_DIR=/opt/saptta/backups
BACKUP_KEEP_DAYS=30

# ── Anthropic AI ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE-ME-your-anthropic-key

# ── Sentry (optional) ─────────────────────────────────────────────────────
FIN_SENTRY_DSN=
HR_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
