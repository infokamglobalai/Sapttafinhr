# ==== Django ====
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# ==== Database (PostgreSQL) ====
POSTGRES_DB=finsaptta
POSTGRES_USER=finsaptta
POSTGRES_PASSWORD=finsaptta
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==== Redis ====
REDIS_URL=redis://redis:6379/0

# ==== JWT ====
JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7

# ==== CORS ====
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==== Frontend ====
# Must hit the tenant subdomain so django-tenants routes to the right schema.
VITE_API_BASE_URL=http://acme.localhost:8000/api/v1
