# ── Saptta unified front-end env ──────────────────────────────────────────
# Copy to .env.local and adjust for your setup.

# FIN platform API (public schema): auth + SaaS subscriptions/entitlements
#
# • Docker stack (`docker compose up`): use the nginx front door on :8080
# • Local Vite + exposed fin-backend port 8000: use :8000 (see docker-compose ports)
VITE_PLATFORM_API_BASE_URL=http://localhost:8080/api/v1

# FIN tenant API (per-tenant schema): business resources.
# django-tenants resolves the tenant from the subdomain — keep {workspace}.
VITE_TENANT_API_BASE_URL=http://{workspace}.localhost:8080/api/v1

# Default workspace (dev tenant created by the backend `bootstrap_dev` command)
VITE_DEFAULT_WORKSPACE=acme

# HR backend origin (its existing pages, opened from the app shell).
# Via the unified front door this is the HR host; standalone dev it's :8001.
VITE_HR_BASE_URL=http://hr.localhost:8080

# Web3Forms (marketing contact form)
VITE_WEB3FORMS_KEY=67801ccb-a93c-433a-9879-b481bd552d44
