# ============================================================
# HRMS Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=hrms.settings.production
SECRET_KEY=your-50-char-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourbrand.com,*.yourbrand.com,localhost

# Domain config
SUPERADMIN_DOMAIN=app.yourbrand.com
TENANT_DOMAIN=yourbrand.com

# Database (DigitalOcean Managed PostgreSQL)
DB_NAME=hrms_prod
DB_USER=hrms_user
DB_PASSWORD=your-db-password
DB_HOST=db-postgresql-blr1-xxxxx.db.ondigitalocean.com
DB_PORT=25060

# Redis (DigitalOcean Managed Redis)
REDIS_URL=rediss://:your-redis-password@redis-blr1-xxxxx.db.ondigitalocean.com:25061/0

# HR Celery uses Redis DB 1 in production (set on hr-worker service)
# HR_REDIS_URL=rediss://:your-redis-password@redis-blr1-xxxxx.db.ondigitalocean.com:25061/1

# DigitalOcean Spaces (S3-compatible)
USE_DO_SPACES=True
SPACES_ACCESS_KEY=your-spaces-access-key
SPACES_SECRET_KEY=your-spaces-secret-key
SPACES_BUCKET_NAME=hrms-prod-files
SPACES_ENDPOINT_URL=https://blr1.digitaloceanspaces.com
SPACES_REGION=blr1

# Email (AWS SES)
EMAIL_BACKEND=anymail.backends.amazon_ses.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourbrand.com
AWS_SES_REGION=ap-south-1
# AWS credentials for SES (use IAM role on server if possible, otherwise set here)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Encryption key for PII fields (Aadhaar, bank accounts)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Sentry (optional but recommended for production)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# AI features (optional) — required only for #1 Review Drafter and other LLM-backed features.
# Get a key at https://console.anthropic.com. Leave blank to disable AI features.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
