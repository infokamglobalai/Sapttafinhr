# ─────────────────────────────────────────────────────────────────────────
# Saptta unified dev stack — copy to `.env` (read by docker compose).
#
# Generate strong secrets:
#   Django keys : python -c "import secrets; print(secrets.token_urlsafe(48))"
#   Fernet key  : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────────────────────────────────────

# Postgres (FIN backend uses this; shared by db + fin services)
POSTGRES_DB=finsaptta
POSTGRES_USER=finsaptta
POSTGRES_PASSWORD=change-me-strong-db-password

# Django secret keys — MUST be 32+ bytes (SimpleJWT signs with these; a short
# key triggers InsecureKeyLengthWarning and is unsafe). Generate per above.
FIN_SECRET_KEY=replace-with-48+-char-random-string
HR_SECRET_KEY=replace-with-another-48+-char-random-string

# HR PII encryption (Fernet, exactly a 32-byte urlsafe-base64 key). Generate per above.
HR_FIELD_ENCRYPTION_KEY=replace-with-a-fernet-key

# Shared secret for HR single sign-on — MUST be identical for fin + hr backends.
SSO_SHARED_SECRET=replace-with-a-shared-sso-secret

# FIN → HR internal provisioning (Docker default: http://hr-backend:8000)
HR_INTERNAL_BASE_URL=http://hr-backend:8000

# Razorpay billing — required for checkout (local + production).
# Local/Docker: use TEST keys (rzp_test_…) — never commit real keys to git.
# Production:   use LIVE keys (rzp_live_…) on the server only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Production webhook URL: https://saptta.com/api/v1/saas/billing/webhook/
# Optional: keep live keys commented on dev machines
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...

# Email (production) — console backend is used when unset
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Saptta <no-reply@saptta.in>

# HR production — Redis DB 1 (Finance uses 0). Required for Celery beat reminders.
HR_REDIS_URL=redis://redis:6379/1
