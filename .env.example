# ─────────────────────────────────────────────────────────────────────────
# Saptta unified dev stack — copy to `.env` (read by docker compose).
# ─────────────────────────────────────────────────────────────────────────

# Postgres (FIN backend uses this; shared by db + fin services)
POSTGRES_DB=finsaptta
POSTGRES_USER=finsaptta
POSTGRES_PASSWORD=finsaptta

# Django secrets (change for anything non-local)
FIN_SECRET_KEY=insecure-dev-key-change-me
HR_SECRET_KEY=insecure-dev-hr-key-change-me

# HR PII encryption (Fernet). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HR_FIELD_ENCRYPTION_KEY=
